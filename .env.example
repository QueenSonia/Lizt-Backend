PORT=
NODE_ENV=production

# WhatsApp Configuration
# Set to true to use simulator mode (for development/testing)
WHATSAPP_SIMULATOR=true

JWT_SECRET=
# Access token expires in 7 days, refresh token in 30 days
JWT_ACCESS_EXPIRY=7d
JWT_REFRESH_EXPIRY=30d
# GMAIL_USER =
# GMAIL_PASSWORD = 

SMTP_HOST=
SMTP_USER = 
SMTP_PASSWORD =

GMAIL_USER = 
GMAIL_USER = 
GMAIL_PASSWORD = 

SENDGRID_API_KEY_ID=
SENDGRID_API_KEY=

FRONTEND_URL =
DEFAULT_PER_PAGE = 
DEFAULT_PAGE_NO = 
CLOUDINARY_NAME =
API_KEY = 
API_SECRET = 

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

WA_PHONE_NUMBER_ID=
CLOUD_API_ACCESS_TOKEN=

AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=

TAWK_WEBHOOK_SECRET=
# TAWK_WEBHOOK_SECRET=

#PRODUCTION
PROD_PORT = 
PROD_DB_NAME = 
PROD_DB_HOST =
PROD_DB_PASSWORD =
PROD_DB_USERNAME = 
PROD_DB_SSL=

# ── Payment gateway ─────────────────────────────────────────────────────────
# Which gateway NEW payments initialize through: 'monnify' | 'paystack'.
# Historical/in-flight references keep verifying against the gateway recorded
# on their row regardless of this value.
PAYMENT_GATEWAY=monnify

# Monnify (active gateway)
# Get your keys from https://app.monnify.com (Developers → API Keys).
# Sandbox base URL for testing; switch to https://api.monnify.com for live.
# Dashboard setup: set the Transaction Completion webhook URL to
#   https://<api-host>/webhooks/monnify
MONNIFY_API_KEY=MK_TEST_xxxxxxxxxxxx
MONNIFY_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxx
MONNIFY_CONTRACT_CODE=xxxxxxxxxxxx
MONNIFY_BASE_URL=https://sandbox.monnify.com
# Escape hatch ONLY if sandbox E2E proves webhooks arrive unsigned — never in
# production:
# MONNIFY_ALLOW_UNSIGNED_WEBHOOKS=true

# Paystack (LEGACY adapter — verify + webhooks for pre-cutover references).
# Keep the secret key until in-flight Paystack references drain (~30 days
# after the Monnify flip); its absence degrades Paystack calls to 503, it no
# longer blocks boot. Remove alongside the legacy-retire PR.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
PAYSTACK_MODE=test

# Live Mode (for production - uncomment when ready)
# PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx
# PAYSTACK_MODE=live






# Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Error Tracking (Sentry)
SENTRY_DSN=
